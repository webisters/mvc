{
    "name": "webisters/mvc",
    "description": "Webisters MVC Library",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "app",
        "application",
        "mvc",
        "model",
        "view",
        "controller",
        "entity",
        "layout",
        "pages",
        "api",
        "resource",
        "presenter",
        "rest",
        "restful"
    ],
    "authors": [
        {
            "name": "Hafiz Muhammad Moaz",
            "email": "hafizmoazkhalid@gmail.com",
            "homepage": "https://github.com/HafizMMoaz"
        }
    ],
    "homepage": "https://webisters.com/packages/mvc",
    "support": {
        "email": "support@webisters.com",
        "issues": "https://github.com/webisters/mvc/issues",
        "forum": "https://github.com/webisters/forum",
        "source": "https://github.com/webisters/mvc",
        "docs": "https://webisters.com"
    },
    "funding": [
        {
            "type": "Webisters Sponsor",
            "url": "https://webisters.com/sponsor"
        }
    ],
    "require": {
        "php": ">=8.2",
        "ext-json": "*",
        "ext-mysqli": "*",
        "webisters/autoload": "*",
        "webisters/cache": "*",
        "webisters/cli": "*",
        "webisters/config": "*",
        "webisters/database": "*",
        "webisters/database-extra": "*",
        "webisters/date": "*",
        "webisters/debug": "*",
        "webisters/email": "*",
        "webisters/http": "*",
        "webisters/language": "*",
        "webisters/log": "*",
        "webisters/pagination": "*",
        "webisters/routing": "*",
        "webisters/session": "*",
        "webisters/validation": "*"
    },
    "require-dev": {
        "webisters/coding-standard": "*",
        "jetbrains/phpstorm-attributes": "^1.2",
        "phpunit/phpunit": "^10.5"
    },
    "minimum-stability": "dev",
    "prefer-stable": true,
    "autoload": {
        "psr-4": {
            "Framework\\MVC\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\MVC\\": "tests/"
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true
    }
}


